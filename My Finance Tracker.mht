.progress-fill { height: 100%; border-radius: 100px; transition: width 0.4s; }

.modal-overlay { position: fixed; inset: 0px; background: rgba(0, 0, 0, 0.75); display: flex; align-items: center; justify-content: center; z-index: 1000; padding: 1rem; animation: 0.15s ease 0s 1 normal none running fadeIn; }

