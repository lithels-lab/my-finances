.input { width: 100%; background: var(--surface2); border: 1px solid var(--border); border-radius: 8px; color: var(--text); padding: 0.6rem 0.8rem; font-size: 0.9rem; outline: none; transition: border-color 0.2s; }

.input:focus { border-color: var(--accent); }

.btn-save { width: 100%; background: linear-gradient(135deg, var(--accent), var(--accent2)); border-width: medium; border-style: none; border-color: currentcolor; border-image: initial; border-radius: 9px; color: rgb(255, 255, 255); padding: 0.8rem; font-weight: 700; cursor: pointer; font-size: 0.95rem; margin-top: 0.5rem; transition: opacity 0.2s; }

.btn-save:hover { opacity: 0.88; }

.two-col { display: grid; grid-template-columns: 1fr 1fr; gap: 0.75rem; }

.ie-grid { display: grid; grid-template-columns: 1fr 1fr; gap: 1.25rem; }

