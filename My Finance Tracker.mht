  .ie-grid { grid-template-columns: 1fr; }
}

.check-circle { width: 22px; height: 22px; border-radius: 50%; border: 2px solid var(--border); background: transparent; cursor: pointer; flex-shrink: 0; display: flex; align-items: center; justify-content: center; font-size: 0.7rem; font-weight: 900; color: rgb(0, 0, 0); transition: 0.2s; }

.check-circle.checked { background: var(--green); border-color: var(--green); }

.emoji-row { display: flex; gap: 0.4rem; flex-wrap: wrap; }

.emoji-btn { background: transparent; border: 1px solid var(--border); border-radius: 6px; padding: 0.3rem 0.45rem; cursor: pointer; font-size: 1.1rem; transition: 0.15s; }

.emoji-btn.selected { background: var(--surface2); border-color: var(--accent); }

