.alert-red { background: rgba(248, 113, 113, 0.08); border: 1px solid rgba(248, 113, 113, 0.3); color: var(--red); }

.alert-green { background: rgba(74, 222, 128, 0.08); border: 1px solid rgba(74, 222, 128, 0.3); color: var(--green); }

#install-banner { position: fixed; bottom: calc(var(--safe-bottom) + 1rem); left: 1rem; right: 1rem; background: var(--surface2); border: 1px solid var(--accent); border-radius: 14px; padding: 1rem 1.25rem; display: none; align-items: center; gap: 1rem; z-index: 500; box-shadow: rgba(0, 0, 0, 0.6) 0px 8px 30px; max-width: 500px; margin: 0px auto; }

