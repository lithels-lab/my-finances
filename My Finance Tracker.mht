::-webkit-scrollbar-track { background: transparent; }

::-webkit-scrollbar-thumb { background: var(--border); border-radius: 4px; }

input, select, button { font-family: var(--sans); }

input::placeholder { color: rgb(58, 61, 74); }

input[type="number"]::-webkit-inner-spin-button { appearance: none; }

select option { background: var(--surface2); }

#app { display: flex; flex-direction: column; min-height: 100vh; }

header { position: sticky; top: 0px; z-index: 200; background: rgba(7, 8, 15, 0.92); backdrop-filter: blur(16px); border-bottom: 1px solid var(--border); padding: calc(var(--safe-top) + 1rem) 1.25rem 1rem; }

.header-inner { max-width: 900px; margin: 0px auto; display: flex; justify-content: space-between; align-items: center; }

.app-title { font-family: var(--serif); font-size: 1.35rem; color: var(--text); }

