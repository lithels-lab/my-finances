*, ::before, ::after { box-sizing: border-box; margin: 0px; padding: 0px; }

:root { --bg: #07080f; --surface: #0f1117; --surface2: #1a1d2e; --border: #2a2d3a; --text: #e8e8f0; --muted: #888; --dim: #555; --accent: #6c63ff; --accent2: #a78bfa; --green: #4ade80; --red: #f87171; --blue: #60a5fa; --yellow: #facc15; --orange: #fb923c; --serif: 'DM Serif Display', serif; --sans: 'DM Sans', sans-serif; --safe-top: env(safe-area-inset-top, 0px); --safe-bottom: env(safe-area-inset-bottom, 0px); }

html { scroll-behavior: smooth; }

body { background: var(--bg); color: var(--text); font-family: var(--sans); min-height: -webkit-fill-available; overscroll-behavior: none; }

