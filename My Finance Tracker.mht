.stat-sub { color: var(--dim); font-size: 0.7rem; margin-top: 0.2rem; }

.section-header { display: flex; justify-content: space-between; align-items: center; margin-bottom: 1rem; flex-wrap: wrap; gap: 0.75rem; }

.section-title { font-family: var(--serif); font-size: 1.15rem; color: var(--text); }

.btn-primary { background: linear-gradient(135deg, var(--accent), var(--accent2)); border-width: medium; border-style: none; border-color: currentcolor; border-image: initial; border-radius: 8px; color: rgb(255, 255, 255); padding: 0.6rem 1.2rem; cursor: pointer; font-weight: 700; font-size: 0.85rem; white-space: nowrap; transition: opacity 0.2s; }

.btn-primary:hover { opacity: 0.88; }

.btn-colored { border-width: medium; border-style: none; border-color: currentcolor; border-image: initial; border-radius: 7px; color: rgb(0, 0, 0); padding: 0.3rem 0.75rem; cursor: pointer; font-weight: 700; font-size: 0.78rem; }

